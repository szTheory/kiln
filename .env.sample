# Phase 1 — required to boot (see README + config/runtime.exs)
DATABASE_URL=ecto://kiln:kiln_dev@localhost:5432/kiln_dev
SECRET_KEY_BASE=replace_me_with_64_random_bytes_via_mix_phx_gen_secret
PHX_HOST=localhost
PORT=4000

# Phase 3 — LLM providers (uncomment when calling live providers)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# Phase 6 — GitHub integration (uncomment when using gh-backed workers)
# GH_TOKEN=

# Phase 9 — dogfood PR worker (fine-grained PAT or installation token; never commit)
# KILN_DOGFOOD_GITHUB_TOKEN=
# KILN_DOGFOOD_REPOSITORY=szTheory/kiln

# Phase 9 — OpenTelemetry traces (optional local dev; see README “Traces”)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Phase 1 Plan 06 — boot-check escape hatch (leave unset; set to "1" only when debugging)
# KILN_SKIP_BOOTCHECKS=

# Phase 3 — DB role override (leave unset in dev — defaults to kiln_app)
# KILN_DB_ROLE=kiln_owner
