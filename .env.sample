# When another Postgres already binds host :5432, set both of these (example uses 5434).
# KILN_DB_HOST_PORT=5434
# DATABASE_URL=ecto://kiln:kiln_dev@localhost:5434/kiln_dev

# Phase 1 — required to boot (see README + config/runtime.exs)
DATABASE_URL=ecto://kiln:kiln_dev@localhost:5432/kiln_dev
# Optional — Dev Container / host-published Postgres: point hostname at the host (not a secret).
# DATABASE_URL=ecto://kiln:kiln_dev@host.docker.internal:5432/kiln_dev
# DATABASE_VERIFIER_URL=ecto://kiln_verifier:kiln_dev_verifier@host.docker.internal:5432/kiln_dev

# Optional — published HTTP from a container (Bandit bind); see README “Optional: Dev Container”.
# KILN_DEV_BIND_ALL=1
SECRET_KEY_BASE=replace_me_with_64_random_bytes_via_mix_phx_gen_secret
PHX_HOST=localhost
PORT=4000

# Phase 3 — LLM providers (uncomment when calling live providers)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# Phase 6 — GitHub integration (uncomment when using gh-backed workers)
# GH_TOKEN=

# Phase 9 — dogfood PR worker (fine-grained PAT or installation token; never commit)
# KILN_DOGFOOD_GITHUB_TOKEN=
# KILN_DOGFOOD_REPOSITORY=szTheory/kiln

# Phase 9 — OpenTelemetry traces (optional local dev; see README “Traces”)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Phase 36 — remote Tailscale profile (fill this from the Tailscale admin console)
# TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional overrides for a non-default host name or local dashboard port.
# TAILSCALE_HOSTNAME=kiln
# TAILSCALE_TUNNEL_TARGET=http://host.docker.internal:4000

# Phase 1 Plan 06 — boot-check escape hatch (leave unset; set to "1" only when debugging)
# KILN_SKIP_BOOTCHECKS=

# Phase 3 — DB role override (leave unset in dev — defaults to kiln_app)
# KILN_DB_ROLE=kiln_owner
