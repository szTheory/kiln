# Phase 1 — required to boot
DATABASE_URL=ecto://kiln:kiln_dev@localhost:5432/kiln_dev
SECRET_KEY_BASE=replace_me_with_64_random_bytes_via_mix_phx_gen_secret
PHX_HOST=localhost
PORT=4000

# Phase 3 — LLM providers (uncomment when Phase 3 ships)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# Phase 6 — GitHub integration (uncomment when Phase 6 ships)
# GH_TOKEN=

# Phase 1 Plan 06 — boot-check escape hatch (leave unset; set to "1" only when debugging)
# KILN_SKIP_BOOTCHECKS=

# Phase 3 — DB role override (Plan 03 activates; leave unset in dev — defaults to kiln_app)
# KILN_DB_ROLE=kiln_owner
