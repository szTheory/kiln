<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Kiln" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const allowed = new Set(["system", "light", "dark"]);

        const setTheme = (theme) => {
          if (!allowed.has(theme)) return;
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };

        const themeFromEvent = (e) => {
          const d = e.detail || {};
          const fromDetail = d.theme ?? d["theme"];
          const fromDispatcher =
            d.dispatcher && d.dispatcher.dataset && d.dispatcher.dataset.phxTheme;
          const fromClosest =
            e.target &&
            e.target.closest &&
            e.target.closest("[data-phx-theme]") &&
            e.target.closest("[data-phx-theme]").dataset.phxTheme;
          return fromDetail || fromDispatcher || fromClosest || null;
        };

        if (!document.documentElement.hasAttribute("data-theme")) {
          const stored = localStorage.getItem("phx:theme");
          setTheme(stored && allowed.has(stored) ? stored : "system");
        }
        window.addEventListener("storage", (e) => {
          if (e.key === "phx:theme") setTheme(e.newValue && allowed.has(e.newValue) ? e.newValue : "system");
        });

        window.addEventListener("phx:set-theme", (e) => {
          const t = themeFromEvent(e);
          if (t) setTheme(t);
        });
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
