{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kiln.local/schemas/scenario_ir_v1.json",
  "title": "Kiln scenario IR v1",
  "type": "object",
  "required": ["scenarios"],
  "additionalProperties": false,
  "properties": {
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scenario" }
    }
  },
  "$defs": {
    "scenario": {
      "type": "object",
      "required": ["id", "description", "steps"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "description": { "type": "string", "maxLength": 500 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["kind", "expect"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["assert"] },
        "expect": { "type": "string", "maxLength": 200 }
      }
    }
  }
}
