{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kiln://audit/v1/model_routing_fallback.json",
  "title": "audit_events model_routing_fallback payload",
  "type": "object",
  "required": [
    "requested_model",
    "actual_model_used",
    "fallback_reason",
    "tier_crossed",
    "attempt_number",
    "wall_clock_ms"
  ],
  "additionalProperties": true,
  "properties": {
    "requested_model": { "type": "string" },
    "actual_model_used": { "type": "string" },
    "fallback_reason": {
      "type": "string",
      "enum": [
        "http_429",
        "http_5xx",
        "connection_error",
        "timeout",
        "context_length_exceeded",
        "content_policy_violation"
      ]
    },
    "tier_crossed": { "type": "boolean" },
    "attempt_number": { "type": "integer", "minimum": 1 },
    "provider_http_status": { "type": ["integer", "null"] },
    "provider": { "type": "string" },
    "role": { "type": "string" },
    "wall_clock_ms": { "type": "integer", "minimum": 0 }
  }
}
